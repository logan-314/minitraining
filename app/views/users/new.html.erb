<script type="text/javascript">
  // On neutralise complètement la fonction de vérification pour forcer le déblocage
  function checkChecked() {
    var bt = document.getElementById("send-button");
    if (bt) {
      bt.disabled = false;
    }
  }

  // Permet de basculer instantanément si le code de conduite est affiché
  function acceptCode() {
    var code = document.getElementById("code-of-conduct");
    var form = document.getElementById("register-form");
    if (code) code.style.display = "none";
    if (form) form.style.display = "block";
  }
</script>

<% provide(:title, 'Inscription') %>

<%# On ignore la fermeture temporaire %>
<div id="code-of-conduct" style="display: none;">
  <h1>Code de conduite</h1>
  <%= render "code_of_conduct", context: "new_user" %>
</div>

<div id="register-form" style="display: block;">
  <h1>Inscription</h1>
  <p class="text-muted">En quelques secondes.</p>

  <%= form_for(@user) do |f| %>
    <%= render 'form', f: f, modif: false %>

    <%# Le bouton est forcé ACTIF d'office (suppression du disabled) %>
    <%= f.submit "Créer mon compte", class: "btn btn-lg btn-success mb-2", id: "send-button" %>
    
  <% end %>
</div>

<script type="text/javascript">
  // Double sécurité pour s'assurer que rien ne bloque le bouton au chargement
  checkChecked();
</script>
